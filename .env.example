# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Токен платёжного провайдера, подключённого через @BotFather -> Bot Settings -> Payments
# (например ЮKassa). НЕОБЯЗАТЕЛЬНО: если оставить пустым, бот работает в режиме
# "ручного заказа" — собирает контакты покупателя, а оплата происходит вне Telegram
# (перевод/наличные). Как только появится провайдер (нужен ИП или самозанятость),
# впишите сюда токен — онлайн-оплата включится автоматически, без правок кода.
PROVIDER_TOKEN=

# Публичный HTTPS-адрес, по которому будет открываться Mini App (например ngrok или ваш домен)
WEBAPP_URL=https://your-domain-or-ngrok-url.example

# Telegram chat_id администратора, куда будут приходить уведомления о заказах
ADMIN_CHAT_ID=123456789

# Валюта заказов (ISO 4217), для Telegram Payments в РФ обычно RUB
CURRENCY=RUB

# Порт, на котором поднимается aiohttp-сервер (веб-приложение + API)
PORT=8080
